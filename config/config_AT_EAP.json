{
    "sequences_paths": ["data/arabidopsis/EAP/enhancer_dataset_full.csv"],
    "results_path": "results/EAP_AT",
    "use_reverse_complement": false,
    "optimizer_type": "adamw",
    "weight_decay": 0.01,
    "momentum": 0.95,
    "use_scheduler": false,
    "max_epochs": 100,
    "warmup_steps": 5,
    "warmup_begin_lr": 0.0001,
    "max_lr": 0.0001,
    "final_lr": 0.0001,
    "lazyLoad": false,
    "metric": "auprc",
    "batchSize": 128,
    "num_workers": 0,
    "counter_for_early_stop_threshold": 5,
    "epochs_to_check_loss": 1,
    "n_accumulated_batches": 1,
    "n_filters": 512,
    "encoder_type": "attention",
    "embed_dim": 2048,
    "num_heads" : 8,
    "dim_forwardfeed" : 2048,
    "dropout" : 0.2,
    "encoder_num_layers" : 6,
    "decoder_num_layers" : 0,
    "expand_factor": 2,
    "n_features": [2],
    "find_unused_parameters": false,
    "use_pos_encoding": true,    
    "max_seq_length": 100
}